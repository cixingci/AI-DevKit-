{
  "card_type": "需求分析",
  "name": "User Story",
  "description": "用户故事卡片",
  "json_schema": {
    "type": "object",
    "properties": {
      "user_stories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {"type": "string"},
            "description": {"type": "string"},
            "acceptance_criteria": {
              "type": "array",
              "items": {"type": "string"}
            },
            "priority": {"type": "string", "enum": ["high", "medium", "low"]},
            "status": {"type": "string", "default": "backlog"}
          },
          "required": ["title", "description"]
        }
      },
      "functional_requirements": {
        "type": "array",
        "items": {"type": "string"}
      },
      "non_functional_requirements": {
        "type": "object",
        "properties": {
          "performance": {"type": "string"},
          "security": {"type": "string"},
          "scalability": {"type": "string"}
        }
      },
      "constraints": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "description": {"type": "string"},
            "value": {"type": "string"}
          }
        }
      },
      "assumptions": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  },
  "ai_params": {
    "prompt_template": "分析以下需求，生成更详细的功能规格说明：\n\n{{content}}",
    "temperature": 0.7,
    "max_tokens": 1000
  },
  "default_view": "form"
}